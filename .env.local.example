# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs (create in Stripe Dashboard)
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_BUSINESS_PRICE_ID=
STRIPE_AGENCY_PRICE_ID=
STRIPE_TOPUP_SMALL_PRICE_ID=
STRIPE_TOPUP_MEDIUM_PRICE_ID=
STRIPE_TOPUP_LARGE_PRICE_ID=
STRIPE_TOPUP_XL_PRICE_ID=

# AI APIs
GOOGLE_GEMINI_API_KEY=
OPENAI_API_KEY=
REPLICATE_API_TOKEN=
ELEVENLABS_API_KEY=

# AI model overrides (optional) — defaults live in lib/ai/models.ts.
# Set these to swap a model without a code change or redeploy.
# ⚠ Verify any ID against the provider's model list first: an unknown ID fails at
#   runtime, not at build time.
# PYRA_MODEL_GEMINI_IMAGE=gemini-3.1-flash-image
# PYRA_MODEL_GEMINI_IMAGE_PRO=gemini-3-pro-image
# PYRA_MODEL_GEMINI_TEXT=gemini-3.1-flash-lite
# PYRA_MODEL_OPENAI_IMAGE=gpt-image-2
# PYRA_MODEL_OPENAI_TEXT=gpt-5.4-mini
# PYRA_MODEL_OPENAI_TTS=gpt-4o-mini-tts
# PYRA_MODEL_ELEVENLABS=eleven_v3
# PYRA_MODEL_FLUX=black-forest-labs/flux-1.1-pro

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=ar

# Admin Dashboard
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_JWT_SECRET=

# Analytics
NEXT_PUBLIC_POSTHOG_KEY=
SENTRY_DSN=

# ElevenLabs Arabic voice overrides (optional) — defaults in lib/ai/elevenlabs.ts.
# Voice Library voices must be added to your ElevenLabs account before the API
# accepts their IDs. Verify with: GET https://api.elevenlabs.io/v1/voices
# PYRA_VOICE_MALE_GULF=rUaPbzcZIu8df8iNL9WZ
# PYRA_VOICE_FEMALE_GULF=gVzwmdZzRgBrNjXaTmi5
# PYRA_VOICE_MALE_MSA=xvhpbk8otnNHtT3fjCpr
# PYRA_VOICE_FEMALE_MSA=ML7jGRDg4E9hIl5qEm1Z
# PYRA_VOICE_NARRATOR=G1HOkzin3NMwRHSq60UI
# PYRA_VOICE_PREMIUM_MALE=8KMBeKnOSHXjLqGuWsAE
# PYRA_VOICE_PREMIUM_FEMALE=kdUY91gH5xyDHapxlthT
